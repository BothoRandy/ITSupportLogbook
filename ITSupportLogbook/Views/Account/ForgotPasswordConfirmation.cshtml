@{
    ViewData["Title"] = "Reset Link Sent";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">

                <div class="mb-4">
                    <img src="~/images/MWHS.jpg" alt="MWHS Logo" style="height:90px; width:auto;" />
                    <h3 class="mt-3 mb-1 fw-bold">Check your email</h3>
                    <div class="small text-muted">If that email exists in our system, a reset link has been sent.</div>
                </div>

                <a asp-action="Login" class="btn btn-primary w-100">Back to Login</a>
            </div>
        </div>
    </div>
</div>