@model ITSupportLogbook.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <img src="~/images/MWHS.jpg" alt="MWHS Logo" style="height:90px; width:auto;" />
                    <h3 class="mt-3 mb-1 fw-bold">Reset Password</h3>
                    <div class="small text-muted">Enter your new password below</div>
                </div>

                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <div class="pwd-wrapper position-relative">
                            <input asp-for="Password" type="password" class="form-control pe-5" id="resetPassword" />
                            <button type="button"
                                    class="btn position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent me-2"
                                    onclick="togglePassword('resetPassword', 'resetToggleIcon')">
                                <i id="resetToggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <div class="pwd-wrapper position-relative">
                            <input asp-for="ConfirmPassword" type="password" class="form-control pe-5" id="confirmResetPassword" />
                            <button type="button"
                                    class="btn position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent me-2"
                                    onclick="togglePassword('confirmResetPassword', 'confirmResetToggleIcon')">
                                <i id="confirmResetToggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button class="btn btn-primary w-100" type="submit">Reset Password</button>

                    <div class="mt-3 text-center">
                        <a asp-action="Login">Back to Login</a>
                    </div>

                    <div class="text-danger mt-3">
                        @Html.ValidationSummary(false)
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, iconId) {
            const passwordInput = document.getElementById(inputId);
            const toggleIcon = document.getElementById(iconId);

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                toggleIcon.classList.remove("bi-eye");
                toggleIcon.classList.add("bi-eye-slash");
            } else {
                passwordInput.type = "password";
                toggleIcon.classList.remove("bi-eye-slash");
                toggleIcon.classList.add("bi-eye");
            }
        }
    </script>
}