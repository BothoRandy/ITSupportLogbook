@model ITSupportLogbook.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="mb-3">Register</h3>

                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label">Firstname</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Lastname</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>


                    <div class="mb-3">
                        <label class="form-label">Password</label>

                        <div class="pwd-wrapper position-relative">
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control pe-5"
                                   id="registerPassword" />

                            <button type="button"
                                    class="btn position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent me-2"
                                    onclick="togglePassword('registerPassword', 'registerToggleIcon')">
                                <i id="registerToggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>

                        <div class="pwd-wrapper position-relative">
                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control pe-5"
                                   id="confirmPassword" />

                            <button type="button"
                                    class="btn position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent me-2"
                                    onclick="togglePassword('confirmPassword', 'confirmToggleIcon')">
                                <i id="confirmToggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button class="btn btn-success w-100" type="submit">Create account</button>

                    <div class="mt-3 text-center">
                        <a asp-action="Login">Already have an account? Login</a>
                    </div>

                    <div class="text-danger mt-3">
                        @Html.ValidationSummary(false)
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, iconId) {
            const passwordInput = document.getElementById(inputId);
            const toggleIcon = document.getElementById(iconId);

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                toggleIcon.classList.remove("bi-eye");
                toggleIcon.classList.add("bi-eye-slash");
            } else {
                passwordInput.type = "password";
                toggleIcon.classList.remove("bi-eye-slash");
                toggleIcon.classList.add("bi-eye");
            }
        }
    </script>
}
