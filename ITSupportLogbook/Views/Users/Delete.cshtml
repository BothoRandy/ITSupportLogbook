@model ITSupportLogbook.Models.ApplicationUser
@{
    ViewData["Title"] = "Delete User";
}

<h2>Delete User</h2>
<p>Are you sure you want to delete <strong>@Model.UserName</strong>?</p>

<form method="post">
    <button class="btn btn-danger" type="submit">Yes, Delete</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>