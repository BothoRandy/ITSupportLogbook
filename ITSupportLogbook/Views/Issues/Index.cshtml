@model IEnumerable<ITSupportLogbook.Models.Issue>

@{
    ViewData["Title"] = "Support Logs";

    var total = Model.Count();
    var open = Model.Count(x => x.Status == "Pending" || x.Status == "Open");
    var resolved = Model.Count(x => x.Status == "Resolved" || x.DateResolved != null);

    var currentFilter = (string?)ViewData["CurrentFilter"];
    var fromDate = (string?)ViewData["FromDate"];
    var toDate = (string?)ViewData["ToDate"];
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div class="d-flex align-items-center gap-3">
        <img src="~/images/MWHS.jpg" alt="MWHS Logo" style="height:60px; width:auto;" />

        <div>
            <h1 class="mb-1 fw-bold">Support Logs</h1>
            <div class="small-muted">Track support requests • Filter by date range • Export for reports</div>
        </div>
    </div>

    <div class="d-flex flex-column align-items-end gap-2">

        <!-- Filter Bar -->
        <form asp-action="Index"
              method="get"
              class="d-flex gap-2 align-items-center flex-wrap justify-content-end">

            <input type="text"
                   name="searchString"
                   value="@currentFilter"
                   class="form-control"
                   placeholder="Search officer / extension / issue / status..."
                   style="width: 260px;" />

            <input type="date"
                   name="fromDate"
                   value="@fromDate"
                   class="form-control"
                   title="From date"
                   style="width: 170px;" />

            <input type="date"
                   name="toDate"
                   value="@toDate"
                   class="form-control"
                   title="To date"
                   style="width: 170px;" />

            <button type="submit" class="btn btn-outline-primary">
                Filter
            </button>
        </form>

        <!-- Actions -->
        <div class="d-flex gap-2 flex-wrap justify-content-end">
            <a class="btn btn-outline-success"
               asp-action="ExportCsv"
               asp-route-searchString="@currentFilter"
               asp-route-fromDate="@fromDate"
               asp-route-toDate="@toDate">
                Export CSV
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Reset
            </a>

            <a class="btn btn-primary" asp-action="Create">
                + Add New Log
            </a>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted">Total Logs</div>
                    <div class="fs-3 fw-bold">@total</div>
                </div>
                <span class="badge bg-primary-subtle text-primary p-3">All</span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted">Open</div>
                    <div class="fs-3 fw-bold">@open</div>
                </div>
                <span class="badge bg-warning-subtle text-warning p-3">Open</span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted">Resolved</div>
                    <div class="fs-3 fw-bold">@resolved</div>
                </div>
                <span class="badge bg-success-subtle text-success p-3">Done</span>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <div class="fw-semibold">Log Entries</div>
            <div class="small-muted">
                Showing @total record(s)
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.OfficerName)</th>
                        <th>@Html.DisplayNameFor(model => model.Extension)</th>
                        <th>@Html.DisplayNameFor(model => model.IssueDescription)</th>
                        <th>@Html.DisplayNameFor(model => model.Status)</th>
                        <th>@Html.DisplayNameFor(model => model.DateReported)</th>
                        <th>@Html.DisplayNameFor(model => model.DateResolved)</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@Html.DisplayFor(modelItem => item.OfficerName)</td>
                            <td>@Html.DisplayFor(modelItem => item.Extension)</td>
                            <td style="max-width: 420px;">
                                <div class="text-truncate" title="@item.IssueDescription">
                                    @Html.DisplayFor(modelItem => item.IssueDescription)
                                </div>
                            </td>
                            <td>
                                @{
                                    var status = item.Status ?? "";
                                }

                                @if (status == "Resolved" || item.DateResolved != null)
                                {
                                    <span class="badge bg-success">Resolved</span>
                                }
                                else if (status == "Open" || status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">@status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@status</span>
                                }
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.DateReported)</td>
                            <td>@Html.DisplayFor(modelItem => item.DateResolved)</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>