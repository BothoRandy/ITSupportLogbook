<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ITSupportLogbook</title>

    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href="~/images/MWHS.jpg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ITSupportLogbook.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-glass shadow-sm sticky-top mb-4">
            <div class="container-fluid">

                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Issues" asp-action="Index">
                    <img src="~/images/MWHS.jpg" alt="MWHS Logo" style="height:42px;" />
                    <span class="fw-semibold">ITSupportLogbook</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Left Navigation -->
                    <ul class="navbar-nav me-auto">

                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Issues" asp-action="Index">
                                    Logs
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Issues" asp-action="Create">
                                    Add New Log
                                </a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-semibold"
                                       asp-controller="Users" asp-action="Index">
                                        Manage Users
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Right Navigation -->
                    <ul class="navbar-nav ms-auto align-items-center">

                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3">
                                <span class="small-muted">
                                    Signed in as <strong>@User.Identity.Name</strong>
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post"
                                      class="d-inline">
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- Page Content -->
    <div class="container">
        <div class="page-shell">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-5 pt-3 pb-3 text-center small-muted">
        &copy; 2026 - ITSupportLogbook • Ministry IT Support System
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>